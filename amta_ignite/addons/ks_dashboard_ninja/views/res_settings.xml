<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="res_config_settings_inherit_view" model="ir.ui.view">
        <field name="name">res.config.settings.inherit.view</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id"
               ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pwa_settings']" position="replace">
               <block title="Progressive Web App" id="pwa_settings" groups="base.group_no_one">
                    <setting help="This name will be used for the application when Ignite is installed through the browser.">
                        <field name="web_app_name" placeholder="Ignite"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>

 
</odoo>
