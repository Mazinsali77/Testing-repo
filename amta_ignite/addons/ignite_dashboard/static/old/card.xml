<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="ignite_dashboard.Card" owl="1">
        <div t-attf-class="#{props.className} overflow-hidden rounded-lg bg-white hover:bg-indigo-100 px-4 py-5 shadow-sm sm:p-6 animate__animated animate__fadeInLeft">
            <t t-if="props.slots.title"> 
                <h5 class="truncate text-md font-medium text-gray-500"><t t-slot="title"/></h5>
            </t>
            <p class="mt-1 text-3xl font-semibold tracking-tight text-gray-900"><t t-slot="default"/></p>
        </div>
    </t>
</templates>